{
    "name": "Ubuntu 24.04",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "xaver.clang-format",
                "llvm-vs-code-extensions.vscode-clangd",
                "ms-vscode.cmake-tools"
            ],
            "settings": {
                "clangd.path": "/usr/bin/clangd",
                "clangd.arguments": [
                    "--compile-commands-dir=${containerWorkspaceFolder}/build_devcontainer"
                ],
                "cmake.configurePreset": "devcontainer",
                "cmake.ctest.testSuiteDelimiter": "/",
                "cmake.testEnvironment": {
                    "BOOST_TEST_COLOR_OUTPUT": "0"
                }
            }
        }
    },
    "containerEnv": {
        "CXXFLAGS": "-Wno-psabi",
        "CCACHE_DIR": "/ccache",
        "LC_ALL": "C.UTF-8",
        "LANG": "C.UTF-8"
    },
    "mounts": [
        "source=acts-ccache,target=/ccache,type=volume"
    ],
    "postCreateCommand": "bash .devcontainer/setup.sh ${containerWorkspaceFolder}"
}
