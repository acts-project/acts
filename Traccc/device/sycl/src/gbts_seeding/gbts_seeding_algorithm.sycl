// ===========================================================================
// gbts_seeding_algorithm: kernel launchers
// ===========================================================================

gbts_seeding_algorithm::gbts_seeding_algorithm(
    const gbts_seedfinder_config& cfg, const memory_resource& mr,
    const vecmem::copy& copy, queue_wrapper& queue,
    std::unique_ptr<const Logger> logger)
    : device::gbts_seeding_algorithm(cfg, mr, copy, std::move(logger)),
      sycl::algorithm_base{queue} {}

void gbts_seeding_algorithm::gbts_count_spacepoints_by_layer_kernel(
    const device::gbts_count_spacepoints_by_layer_payload& payload) const {
  ::sycl::queue& squeue = details::get_queue(queue());
  squeue.throw_asynchronous();

  const unsigned int n_threads = 128;
  squeue.submit([&](::sycl::handler& h) {
    h.parallel_for<kernels::gbts_count_spacepoints_by_layer>(
        details::calculate1DimNdRange(payload.nSp, n_threads),
        [payload](::sycl::nd_item<1> item) {
          device::gbts_count_spacepoints_by_layer(details::thread_id<1>{item},
                                                  payload);
        });
  });

  oneapi::dpl::inclusive_scan(
      oneapi::dpl::execution::device_policy{squeue}, payload.layerCounts.ptr(),
      payload.layerCounts.ptr() + payload.layerCounts.capacity(),
      payload.layerCounts.ptr());
}

