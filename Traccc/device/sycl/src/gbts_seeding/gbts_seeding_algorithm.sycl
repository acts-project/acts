void gbts_seeding_algorithm::gbts_make_graph_edges_kernel(
    const device::gbts_make_graph_edges_payload& payload) const {
  ::sycl::queue& squeue = details::get_queue(queue());
  squeue.throw_asynchronous();

  const unsigned int n_threads = 128;
  const unsigned int n_blocks = payload.nUsedBinPairs;
  squeue.submit([&](::sycl::handler& h) {
    // Shared-memory scratch: a block-local copy of the current node1 chunk.
    vecmem::sycl::local_accessor<float> phi(
        traccc::device::gbts_consts::node_buffer_length, h);
    vecmem::sycl::local_accessor<traccc::float4> node_pack(
        traccc::device::gbts_consts::node_buffer_length, h);

    h.parallel_for<kernels::gbts_make_graph_edges>(
        details::calculate1DimNdRange(n_blocks * n_threads, n_threads),
        [payload, phi, node_pack](::sycl::nd_item<1> item) {
          const details::barrier<1> barrier{item};
          device::gbts_make_graph_edges(
              details::thread_id<1>{item}, barrier, payload,
              {vecmem::data::vector_view<float>(
                   traccc::device::gbts_consts::node_buffer_length, &phi[0]),
               vecmem::data::vector_view<traccc::float4>(
                   traccc::device::gbts_consts::node_buffer_length,
                   &node_pack[0])});
        });
  });

  vecmem::device_vector<unsigned int> d_num_outgoing_edges(
      payload.num_outgoing_edges);
  oneapi::dpl::inclusive_scan(oneapi::dpl::execution::device_policy{squeue},
                              d_num_outgoing_edges.begin(),
                              d_num_outgoing_edges.end(),
                              d_num_outgoing_edges.begin());
}

