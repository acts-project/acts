void gbts_seeding_algorithm::gbts_count_eta_phi_bins_kernel(
    const device::gbts_count_eta_phi_bins_payload& payload) const {
  ::sycl::queue& squeue = details::get_queue(queue());
  squeue.throw_asynchronous();

  const unsigned int n_threads = 128;
  squeue.submit([&](::sycl::handler& h) {
    h.parallel_for<kernels::gbts_count_eta_phi_bins>(
        details::calculate1DimNdRange(payload.nEtaBins, n_threads),
        [payload](::sycl::nd_item<1> item) {
          device::gbts_count_eta_phi_bins(details::thread_id<1>{item}, payload);
        });
  });

  vecmem::device_vector<unsigned int> d_eta_sums(payload.eta_node_counter);
  oneapi::dpl::inclusive_scan(oneapi::dpl::execution::device_policy{squeue},
                              d_eta_sums.begin(), d_eta_sums.end(),
                              d_eta_sums.begin());
}

