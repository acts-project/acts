# ---------------------------------------------------------------------------
# Plot rule: ntuple ROOT -> histogrammed ROOT via Examples/Scripts/generic_plotter.py.
# ---------------------------------------------------------------------------

def _plot_input(wildcards):
    return f"{OUTDIR}/data/" + PLOTS[wildcards.rel + "_hist.root"]["from"]

def _plot_tree(wildcards):
    return PLOTS[wildcards.rel + "_hist.root"]["tree"]

def _plot_config(wildcards):
    return f"{HISTCMP_CONFIG_DIR}/" + PLOTS[wildcards.rel + "_hist.root"]["config"]


rule plot_hist:
    input:
        ntuple = _plot_input,
    output:
        hist    = f"{OUTDIR}/data/{{rel}}_hist.root",
        witness = f"{OUTDIR}/witnesses/plot/{{rel}}_hist.json",
    params:
        tree   = _plot_tree,
        config = _plot_config,
    log:
        f"{OUTDIR}/logs/plot_{{rel}}_hist.log",
    shell:
        WRAP + " --witness {output.witness} --step plot --log {log} "
        "--touches '{output}' -- "
        "python3 Examples/Scripts/generic_plotter.py "
        "{input.ntuple} {params.tree} {output.hist} "
        "--silent --config {params.config}"


# ---------------------------------------------------------------------------
# histcmp rule.
# ---------------------------------------------------------------------------

def _histcmp_current(wildcards):
    return f"{OUTDIR}/data/" + wildcards.rel + ".root"

def _histcmp_reference(wildcards):
    rel = wildcards.rel + ".root"
    comp = COMP_BY_CURRENT[rel]
    ref_rel = comp.get("reference", rel)
    if comp.get("reference_in") == "outdir":
        return f"{OUTDIR}/data/{ref_rel}"
    return f"{REFDIR}/{ref_rel}"

def _histcmp_params(wildcards):
    rel = wildcards.rel + ".root"
    comp = COMP_BY_CURRENT[rel]
    cfg = comp.get("config")
    config_flag = f"--config {HISTCMP_CONFIG_DIR}/{cfg}" if cfg else ""
    return {
        "title":       comp["title"],
        "config_flag": config_flag,
        "label_ref":   comp.get("label_reference", "reference"),
        "label_mon":   comp.get("label_monitored", "monitored"),
    }


rule histcmp:
    input:
        current   = _histcmp_current,
        reference = _histcmp_reference,
    output:
        html    = f"{OUTDIR}/html/{{rel}}.html",
        witness = f"{OUTDIR}/witnesses/histcmp/{{rel}}.json",
    params:
        p = _histcmp_params,
    log:
        f"{OUTDIR}/logs/histcmp_{{rel}}.log",
    shell:
        WRAP + " --witness {output.witness} --step histcmp --log {log} "
        "--touches '{output}' -- "
        "histcmp {input.current} {input.reference} "
        "--label-reference={params.p[label_ref]} "
        "--label-monitored={params.p[label_mon]} "
        "--title={params.p[title]:q} "
        "-o {output.html} "
        "-p {output.html}_plots "
        "{params.p[config_flag]}"


# ---------------------------------------------------------------------------
# build_results: join all witnesses against the catalog into a single rich
# results JSON. The summary rule renders this to md/html.
# ---------------------------------------------------------------------------

def _read_witness(path):
    try:
        return json.loads(Path(path).read_text())
    except (OSError, ValueError):
        return {"step": "?", "rc": -1, "log": None}


def _comparison_row(comp):
    slug, variant = generator_info_for_comp(comp)
    steps = []
    upstream = upstream_slug_for(slug)
    if upstream:
        w = _read_witness(witness_for_generator(upstream))
        steps.append({"kind": "upstream", "name": upstream, "rc": w["rc"], "log": w.get("log")})
    gw = _read_witness(witness_for_generator(slug, variant))
    gen_label = slug + (f"/{variant}" if variant else "")
    steps.append({"kind": "generator", "name": gen_label, "rc": gw["rc"], "log": gw.get("log")})
    if "plot" in comp:
        pw = _read_witness(witness_for_plot(_rel_no_root(comp["current"])))
        steps.append({"kind": "plot", "name": "plot", "rc": pw["rc"], "log": pw.get("log")})
    hw = _read_witness(witness_for_histcmp(_rel_no_root(comp["current"])))
    steps.append({"kind": "histcmp", "name": "histcmp", "rc": hw["rc"], "log": hw.get("log")})
    # Mark cascade: any step after the first failure inherits the failure.
    first_failed = False
    for s in steps:
        if first_failed and s["rc"] != 0:
            s["cascade"] = True
        else:
            s["cascade"] = False
        if s["rc"] != 0:
            first_failed = True
    return {
        "title":     comp["title"],
        "mode":      comp["mode"],
        "report":    "html/" + _rel_no_root(comp["current"]) + ".html",
        "info_only": comp["title"].startswith("Comparison"),
        "steps":     steps,
    }


rule build_results:
    input:
        _all_witnesses(),
    output:
        results = f"{OUTDIR}/physmon_results.json",
    run:
        rows = [_comparison_row(c) for c in COMPARISONS]
        Path(output.results).write_text(json.dumps(rows, indent=2) + "\n")


# ---------------------------------------------------------------------------
# Summary: JSON -> markdown + html. Exits non-zero if any non-info row failed,
# which is what fails snakemake and surfaces failure to CI.
# ---------------------------------------------------------------------------

rule summary:
    input:
        results = f"{OUTDIR}/physmon_results.json",
    output:
        md      = f"{OUTDIR}/summary.md",
        html    = f"{OUTDIR}/summary.html",
    shell:
        "python3 CI/physmon/summary.py {input.results} "
        "--md {output.md} --html {output.html}"
