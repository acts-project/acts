        fitting_ambi        = f"{OUTDIR}/data/trackfinding_ttbar_pu200/performance_fitting_ckf_ambi.root",
        finding_ml_solver   = f"{OUTDIR}/data/trackfinding_ttbar_pu200/performance_finding_ckf_ml_solver.root",
        fitting_ml_solver   = f"{OUTDIR}/data/trackfinding_ttbar_pu200/performance_fitting_ckf_ml_solver.root",
        vtx_amvf_gauss      = temp(f"{OUTDIR}/data/trackfinding_ttbar_pu200/performance_vertexing_amvf_gauss_notime.root"),
        vtx_amvf_grid       = temp(f"{OUTDIR}/data/trackfinding_ttbar_pu200/performance_vertexing_amvf_grid_time.root"),
        witness             = witness_for_generator("trackfinding_ttbar_pu200"),
    log: f"{OUTDIR}/logs/trackfinding_ttbar_pu200.log"
    shell:
        WRAP + " --witness {output.witness} --step generator --log {log} "
        "--touches '{output}' -- "
        "python3 " + WORKFLOWS_DIR + "/physmon_trackfinding_ttbar_pu200.py "
        + OUTDIR + "/data/trackfinding_ttbar_pu200"


rule generate_trackfitting_gx2f_vs_kf:
    output:
        gx2f    = f"{OUTDIR}/data/trackfitting_gx2f_vs_kf/performance_trackfitting_gx2f.root",
        kf      = f"{OUTDIR}/data/trackfitting_gx2f_vs_kf/performance_trackfitting_kf.root",
