# Snakemake workflow for physmon.
#
# Produces the physmon validation artifacts as an explicit DAG so:
#   - Generation and comparison both run in parallel (--cores N).
#   - Editing one generator only re-runs that branch.
#   - The catalog of jobs lives in config/physmon.yaml, not in shell ifs.
#
# Every rule is run through scripts/wrap.sh so it always exits 0 and writes a
# small JSON witness {"step","rc","log"}. The summary step joins those witnesses
# against the catalog to produce a multi-column results table and is the single
# place that decides overall pass/fail. This means even when an upstream step
# fails, the rest of the DAG still runs (on touched-empty stand-in files) and
# the summary shows the full failure chain.
#
# Usage (from repo root, after `source build/this_acts_withdeps.sh`):
#   CI/physmon/scripts/run_snakemake.sh -s CI/physmon/Snakefile --cores N [target]
#
# Always launch via run_snakemake.sh rather than `snakemake` directly: the ACTS
# runtime environment puts ROOT/dd4hep libraries on LD_LIBRARY_PATH (and their
# Python packages on PYTHONPATH) that are ABI-incompatible with snakemake's
# interpreter and segfault the snakemake process itself. The wrapper runs the
# driver with those moved aside and hands the full environment back to the jobs
# it launches (via wrap.sh and the summary rule).
#
# Targets:
#   all              everything + summary  (default; fails non-zero if any comparison failed)
#   simulation, kf, gsf, gx2f, refit_kf, refit_gsf, fullchains, gx2f_vs_kf
#                    per-mode meta-targets. Each builds only its slice of
#                    artifacts and fails non-zero if any in-scope comparison failed.
#
# Override the output directory:
#   snakemake ... --config outdir=/tmp/physmon

import json
from pathlib import Path

configfile: "CI/physmon/config/physmon.yaml"

OUTDIR             = config.get("outdir", "physmon")
REFDIR             = "CI/physmon/reference"
WORKFLOWS_DIR      = "CI/physmon/workflows"
HISTCMP_CONFIG_DIR = "CI/physmon/config"
WRAP               = "bash CI/physmon/scripts/wrap.sh"

# run_snakemake.sh runs the snakemake driver with the ACTS runtime libraries
# moved aside (they crash the interpreter) and stashes them in _PHYSMON_JOB_*.
# wrap.sh restores them for the wrapped generator/histcmp/plot commands; rules
# that shell out without wrap.sh (summary) must restore them too, since python3
# resolves to the ACTS interpreter and needs its libraries. No-op for a bare
# `snakemake` invocation where the vars are unset.
# Braces are doubled: snakemake runs str.format() over the shell string, so
# literal shell ${...} must be escaped as ${{...}}.
RESTORE_JOB_ENV = (
    'export LD_LIBRARY_PATH="${{_PHYSMON_JOB_LD_LIBRARY_PATH-$LD_LIBRARY_PATH}}"; '
    'export PYTHONPATH="${{_PHYSMON_JOB_PYTHONPATH-$PYTHONPATH}}"; '
)

# Thread budget for compute-heavy generator scripts. Setting this equal to the
# whole snakemake budget means at most one heavy rule runs at a time but it
# uses every available core; cheap rules (plot/histcmp/summary) and the three
# Geant4/Pythia8-bound generators (threads: 1) can fill the gaps in parallel.
HEAVY_THREADS = workflow.cores


# ---------------------------------------------------------------------------
# Generator catalog. Lives in Python (next to the rules that define each
# generator) rather than in YAML — the rule bodies are the source of truth
# for what each generator produces; this just declares the relations that
# the catalog needs (variants for output layout, upstream deps for the DAG).
# ---------------------------------------------------------------------------

# All generator slugs the workflow knows about. Used to enumerate witnesses.
GENERATOR_SLUGS = [
    "simulation",
    "simulation_gsf",
    "trackfitting_kf",
    "trackfitting_gsf",
    "trackfitting_gx2f",
    "trackrefitting_kf",
    "trackrefitting_gsf",
    "trackfinding_1muon",
    "trackfinding_4muon_50vertices",
    "trackfinding_ttbar_pu200",
    "trackfitting_gx2f_vs_kf",
]

# Variant -> display label for trackfinding_1muon. Variant keys are the
# `SeedingAlgorithm` enum member names so the script can resolve them via
# `getattr(SeedingAlgorithm, name)`. Display labels stay human-readable.
TRACKFINDING_1MUON_VARIANTS = {
    "TruthSmeared":      "truth smeared seeding",
    "TruthEstimated":    "truth estimated seeding",
    "GridTriplet":       "default seeding",
    "OrthogonalTriplet": "orthogonal seeding",
}

# Generators that have a per-variant output subdir layout. Drives witness paths
# and the comparison -> generator mapping for cascade reporting.
GENERATOR_VARIANTS = {
    "trackfinding_1muon": list(TRACKFINDING_1MUON_VARIANTS),
}

# Generators that depend on another generator's output. Used by build_results
# to attach an "upstream" step to each comparison's row.
GENERATOR_UPSTREAM = {
    "trackfitting_gsf":   "simulation_gsf",
    "trackrefitting_gsf": "simulation_gsf",
}


# ---------------------------------------------------------------------------
# Trackfinding comparison template. The trackfinding workflows produce a
# common pack of comparison files (seeding/finding/fitting/tracksummary), with
# optional ambisolver / ML-solver / vertexing add-ons. Rather than enumerate
# all 31 entries in YAML we expand them here from a short config block.
# ---------------------------------------------------------------------------

# Base pack: 4 rows present for every trackfinding workflow.
TRACKFINDING_BASE = [
    {"kind_fmt": "Seeding {label}",                   "file": "performance_seeding.root",     "config": "default.yml", "skip_variants": ["TruthSmeared"]},
    {"kind_fmt": "CKF finding performance | {label}", "file": "performance_finding_ckf.root", "config": "default.yml"},
    {"kind_fmt": "CKF fitting performance | {label}", "file": "performance_fitting_ckf.root", "config": "default.yml"},
    {"kind_fmt": "CKF track summary | {label}",       "file": "tracksummary_ckf_hist.root",
     "plot": {"from": "tracksummary_ckf.root", "tree": "tracksummary", "config": "tracksummary_ckf.yml"}},
]

# Optional add-on packs, keyed on names the YAML refers to via `extras:`.
TRACKFINDING_EXTRAS = {
    "ambisolver": [
        {"kind_fmt": "Ambisolver finding performance | {label}",
         "file": "performance_finding_ckf_ambi.root"},
    ],
    "ml_solver": [
        {"kind_fmt": "ML Ambisolver | {label}",
         "file": "performance_finding_ckf_ml_solver.root"},
    ],
    "vertexing_ivf": [
        {"kind_fmt": "IVF notime | {label}",
         "file": "performance_vertexing_ivf_notime_hist.root",
         "plot": {"from": "performance_vertexing_ivf_notime.root", "tree": "vertexing",
                  "config": "{vertexing_config}"}},
    ],
    "vertexing_amvf": [
        {"kind_fmt": "AMVF gauss notime | {label}",
         "file": "performance_vertexing_amvf_gauss_notime_hist.root",
         "plot": {"from": "performance_vertexing_amvf_gauss_notime.root", "tree": "vertexing",
                  "config": "{vertexing_config}"}},
        {"kind_fmt": "AMVF grid time | {label}",
         "file": "performance_vertexing_amvf_grid_time_hist.root",
         "plot": {"from": "performance_vertexing_amvf_grid_time.root", "tree": "vertexing",
                  "config": "{vertexing_config}"}},
    ],
}


def _expand_row(slug, variant, label, row, vertexing_config):
    """Expand a single template row into a comparison dict (or None to skip)."""
    if variant is not None and variant in row.get("skip_variants", []):
        return None
    prefix = f"{slug}/{variant}/" if variant is not None else f"{slug}/"
    entry = {
        "title":   row["kind_fmt"].format(label=label),
        "current": prefix + row["file"],
        "mode":    "fullchains",
    }
    if "config" in row:
        entry["config"] = row["config"]
    if "plot" in row:
        plot_cfg = row["plot"]["config"]
        if plot_cfg == "{vertexing_config}":
            assert vertexing_config, f"trackfinding row needs vertexing_config: {row}"
            plot_cfg = vertexing_config
        entry["plot"] = {
            "from":   prefix + row["plot"]["from"],
            "tree":   row["plot"]["tree"],
            "config": plot_cfg,
        }
    return entry


def expand_trackfinding(spec):
    """Expand the YAML `trackfinding:` block into a flat list of comparisons.

    `spec` is config["trackfinding"]: a dict {slug -> per-slug options}.
    Per-slug options:
      - For generators with variants (trackfinding_1muon): `label_fmt` with
        a `{variant_label}` placeholder; variants come from the catalog.
      - Otherwise: a plain `label`.
      - `extras`: optional list of keys from TRACKFINDING_EXTRAS.
      - `vertexing_config`: required if any vertexing extra is used.
    """
    comparisons = []
    for slug, opts in spec.items():
        rows = list(TRACKFINDING_BASE)
        for e in opts.get("extras") or []:
            rows += TRACKFINDING_EXTRAS[e]
        vcfg = opts.get("vertexing_config")
        if slug in GENERATOR_VARIANTS:
            assert "label_fmt" in opts, f"{slug} has variants, needs label_fmt"
            variant_labels = TRACKFINDING_1MUON_VARIANTS  # only generator with variants
            for variant, var_label in variant_labels.items():
                label = opts["label_fmt"].format(variant_label=var_label)
                for row in rows:
                    out = _expand_row(slug, variant, label, row, vcfg)
                    if out is not None:
                        comparisons.append(out)
        else:
            label = opts["label"]
            for row in rows:
                out = _expand_row(slug, None, label, row, vcfg)
                if out is not None:
                    comparisons.append(out)
    return comparisons


# ---------------------------------------------------------------------------
# Catalog: the explicit comparisons from YAML plus trackfinding expansions.
# ---------------------------------------------------------------------------

COMPARISONS = list(config["comparisons"]) + expand_trackfinding(config.get("trackfinding", {}))


# ---------------------------------------------------------------------------
# Catalog indexes
# ---------------------------------------------------------------------------

PLOTS = {c["current"]: c["plot"] for c in COMPARISONS if "plot" in c}
COMP_BY_CURRENT = {c["current"]: c for c in COMPARISONS}


# ---------------------------------------------------------------------------
# Path helpers
# ---------------------------------------------------------------------------

def _rel_no_root(rel):
    """Strip a trailing '.root' from a path-like string."""
    assert rel.endswith(".root"), rel
    return rel[:-len(".root")]


def html_for(comp):
    """{OUTDIR}/html/<current-with-.root-replaced-by-.html>."""
    return f"{OUTDIR}/html/" + _rel_no_root(comp["current"]) + ".html"


def witness_for_generator(slug, variant=None):
    if variant:
        return f"{OUTDIR}/witnesses/generator/{slug}/{variant}.json"
    return f"{OUTDIR}/witnesses/generator/{slug}.json"


def witness_for_plot(rel_no_root):
    return f"{OUTDIR}/witnesses/plot/{rel_no_root}.json"


def witness_for_histcmp(rel_no_root):
    return f"{OUTDIR}/witnesses/histcmp/{rel_no_root}.json"


def generator_info_for_comp(comp):
    """Return (slug, variant) — which generator owns this comparison's `current` file.

    Variant is None unless the generator has variants (currently only trackfinding_1muon).
    """
    parts = comp["current"].split("/")
    slug = parts[0]
    variants = GENERATOR_VARIANTS.get(slug)
    if variants and len(parts) >= 2 and parts[1] in variants:
        return slug, parts[1]
    return slug, None


def upstream_slug_for(slug):
    """Return the upstream generator slug if this generator has one, else None."""
    return GENERATOR_UPSTREAM.get(slug)


def comps_for_mode(mode):
    if mode == "all":
        return COMPARISONS
    return [c for c in COMPARISONS if c["mode"] == mode]


def _check_histcmp_witnesses(comps):
    """Read histcmp witnesses for `comps`; SystemExit(rc|...) if any non-zero.

    Used by per-mode meta-targets so e.g. `snakemake kf` fails when the KF
    comparison failed. The richer multi-column summary still requires `all`.
    """
    import sys
    rc = 0
    failed = []
    for c in comps:
        wpath = witness_for_histcmp(_rel_no_root(c["current"]))
        try:
            w = json.loads(Path(wpath).read_text())
        except (OSError, ValueError) as e:
            print(f"physmon: cannot read witness {wpath}: {e}", file=sys.stderr)
            rc |= 1
            continue
        if w["rc"] != 0:
            rc |= w["rc"]
            failed.append((c["title"], w))
    for title, w in failed:
        log = w.get("log") or "(no log)"
        print(f"physmon: comparison failed: {title} (rc={w['rc']}, log={log})", file=sys.stderr)
    if rc != 0:
        raise SystemExit(rc)


def _all_witnesses():
    """Every witness path the workflow should produce. Used by build_results' input."""
    paths = []
    for slug in GENERATOR_SLUGS:
        variants = GENERATOR_VARIANTS.get(slug)
        if variants:
            for v in variants:
                paths.append(witness_for_generator(slug, v))
        else:
            paths.append(witness_for_generator(slug))
    for c in COMPARISONS:
        if "plot" in c:
            paths.append(witness_for_plot(_rel_no_root(c["current"])))
        paths.append(witness_for_histcmp(_rel_no_root(c["current"])))
    return paths


# ---------------------------------------------------------------------------
# Default target — `all`. Triggers full DAG + summary.
# ---------------------------------------------------------------------------

rule all:
    input:
        f"{OUTDIR}/summary.md",
        f"{OUTDIR}/summary.html",
    default_target: True


# ---------------------------------------------------------------------------
# Per-mode meta-targets. Pull only their slice of comparisons; check their
# histcmp witnesses via a small run: gate so partial runs fail correctly.
# ---------------------------------------------------------------------------

rule simulation:
    input:
        [html_for(c) for c in comps_for_mode("simulation")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("simulation")],
    run: _check_histcmp_witnesses(comps_for_mode("simulation"))

rule kf:
    input:
        [html_for(c) for c in comps_for_mode("kf")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("kf")],
    run: _check_histcmp_witnesses(comps_for_mode("kf"))

rule gsf:
    input:
        [html_for(c) for c in comps_for_mode("gsf")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("gsf")],
    run: _check_histcmp_witnesses(comps_for_mode("gsf"))

rule gx2f:
    input:
        [html_for(c) for c in comps_for_mode("gx2f")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("gx2f")],
    run: _check_histcmp_witnesses(comps_for_mode("gx2f"))

rule refit_kf:
    input:
        [html_for(c) for c in comps_for_mode("refit_kf")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("refit_kf")],
    run: _check_histcmp_witnesses(comps_for_mode("refit_kf"))

rule refit_gsf:
    input:
        [html_for(c) for c in comps_for_mode("refit_gsf")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("refit_gsf")],
    run: _check_histcmp_witnesses(comps_for_mode("refit_gsf"))

rule fullchains:
    input:
        [html_for(c) for c in comps_for_mode("fullchains")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("fullchains")],
    run: _check_histcmp_witnesses(comps_for_mode("fullchains"))

rule gx2f_vs_kf:
    input:
        [html_for(c) for c in comps_for_mode("gx2f_vs_kf")],
        [witness_for_histcmp(_rel_no_root(c["current"])) for c in comps_for_mode("gx2f_vs_kf")],
    run: _check_histcmp_witnesses(comps_for_mode("gx2f_vs_kf"))


# ---------------------------------------------------------------------------
# Generator rules. One per script. Wrapped so they never fail the DAG; outputs
# that feed plot_hist are wrapped in temp() so snakemake auto-cleans the large
# ntuples after they've been consumed (matching the original `rm` in the
# legacy shell script).
# ---------------------------------------------------------------------------

rule generate_simulation:
    output:
        particles_fatras = temp(f"{OUTDIR}/data/simulation/particles_fatras.root"),
        particles_geant4 = temp(f"{OUTDIR}/data/simulation/particles_geant4.root"),
        particles_ttbar  = temp(f"{OUTDIR}/data/simulation/particles_ttbar.root"),
        vertices_ttbar   = temp(f"{OUTDIR}/data/simulation/vertices_ttbar.root"),
        particles_gun    = f"{OUTDIR}/data/simulation/particles_gun.root",
        witness          = witness_for_generator("simulation"),
    log: f"{OUTDIR}/logs/simulation.log"
    shell:
        WRAP + " --witness {output.witness} --step generator --log {log} "
        "--touches '{output}' -- "
        "python3 " + WORKFLOWS_DIR + "/physmon_simulation.py "
        + OUTDIR + "/data/simulation"


rule generate_simulation_gsf:
    output:
        particles = f"{OUTDIR}/data/simulation_gsf/simulation/particles_simulation.root",
        hits      = f"{OUTDIR}/data/simulation_gsf/simulation/hits.root",
        witness   = witness_for_generator("simulation_gsf"),
    log: f"{OUTDIR}/logs/simulation_gsf.log"
    shell:
        WRAP + " --witness {output.witness} --step generator --log {log} "
        "--touches '{output}' -- "
        "python3 " + WORKFLOWS_DIR + "/physmon_simulation_gsf.py "
        + OUTDIR + "/data/simulation_gsf"


