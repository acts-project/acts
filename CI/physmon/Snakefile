# trackfinding_1muon: split into two rules so the output set correctly
# reflects that TruthSmeared does NOT produce performance_seeding.root.

rule generate_trackfinding_1muon_with_seeding:
    output:
        seeding = f"{OUTDIR}/data/trackfinding_1muon/{{variant}}/performance_seeding.root",
        finding = f"{OUTDIR}/data/trackfinding_1muon/{{variant}}/performance_finding_ckf.root",
        fitting = f"{OUTDIR}/data/trackfinding_1muon/{{variant}}/performance_fitting_ckf.root",
        summary = temp(f"{OUTDIR}/data/trackfinding_1muon/{{variant}}/tracksummary_ckf.root"),
        witness = f"{OUTDIR}/witnesses/generator/trackfinding_1muon/{{variant}}.json",
    wildcard_constraints:
        variant = "|".join(v for v in TRACKFINDING_1MUON_VARIANTS if v != "TruthSmeared"),
    log: f"{OUTDIR}/logs/trackfinding_1muon_{{variant}}.log"
    threads: HEAVY_THREADS
    shell:
        WRAP + " --witness {output.witness} --step generator --log {log} "
        "--touches '{output}' -- "
        "python3 " + WORKFLOWS_DIR + "/physmon_trackfinding_1muon.py "
        + OUTDIR + "/data/trackfinding_1muon/{wildcards.variant} "
        "--variant {wildcards.variant} --threads {threads}"


