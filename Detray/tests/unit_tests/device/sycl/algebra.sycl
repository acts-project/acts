// Test include(s).
#include "detray/test/device/sycl/algebra_test_suite.hpp"

// GoogleTest include(s).
#include <gtest/gtest.h>

// System include(s).
#include <string>

namespace detray::test::sycl {

using test_types = testing::Types<detray::test::algebra>;

REGISTER_TYPED_TEST_SUITE_P(sycl_vector_test, vector_2d_ops, vector_3d_ops);
REGISTER_TYPED_TEST_SUITE_P(sycl_matrix_test, matrix64_ops, matrix22_ops);
REGISTER_TYPED_TEST_SUITE_P(sycl_transform_test, transform3D);

INSTANTIATE_TYPED_TEST_SUITE_P(detray_algebra, sycl_vector_test, test_types,
                               test_specialisation_name);
INSTANTIATE_TYPED_TEST_SUITE_P(detray_algebra, sycl_matrix_test, test_types,
                               test_specialisation_name);
INSTANTIATE_TYPED_TEST_SUITE_P(detray_algebra, sycl_transform_test, test_types,
                               test_specialisation_name);

}  // namespace detray::test::sycl
